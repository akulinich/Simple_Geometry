---
import '../styles/global.css';
import 'katex/dist/katex.min.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/ui';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
  otherLangUrl?: string;
}

const { title, lang = 'en', otherLangUrl } = Astro.props;
const t = useTranslations(lang);
const description = Astro.props.description ?? t('meta.description');
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — Simple Geometry</title>
    <link rel="icon" type="image/png" href={`${base}/tor.png`} />
  </head>
  <body>
    <div class="page-wrapper">
      <Header lang={lang} otherLangUrl={otherLangUrl} />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
