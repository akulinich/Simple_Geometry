---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/ui';
import { getArticlesForLang, formatDate } from '../utils/articles';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;

const articles = await getArticlesForLang(lang);

const allTags = Array.from(
  new Set(articles.flatMap(a => a.data.tags ?? []))
).sort((a, b) => a.localeCompare(b, lang));
---

<h1>{t('articles.heading')}</h1>

<div class="articles-controls">
  <input
    type="search"
    id="article-search"
    class="articles-input"
    placeholder={t('articles.search')}
    autocomplete="off"
  />
  <div class="articles-input articles-tag-field" id="article-tag-field">
    <span class="articles-tag-chips" id="article-tag-chips"></span>
    <input
      type="text"
      id="article-tag-input"
      class="articles-tag-bare"
      placeholder={t('articles.tag_filter')}
      list="article-tag-options"
      autocomplete="off"
    />
  </div>
  <datalist id="article-tag-options">
    {allTags.map(tag => <option value={tag} />)}
  </datalist>
  <button type="button" id="article-reset" class="articles-reset">
    {t('articles.clear')}
  </button>
</div>

<ul class="toc-list" id="article-list">
  {articles.map(article => {
    const slug = article.slug.replace(`${lang}/`, '');
    const tags = article.data.tags ?? [];
    return (
      <li
        class="toc-item"
        data-title={(article.data.title ?? slug).toLowerCase()}
        data-tags={tags.join('|').toLowerCase()}
      >
        <a class="toc-title" href={`${base}/${lang}/articles/${slug}`}>
          {article.data.title ?? slug}
        </a>
        <span class="toc-tags">
          {tags.map(tag => (
            <button type="button" class="tag tag-pick" data-tag={tag}>{tag}</button>
          ))}
        </span>
        <span class="toc-date">{formatDate(article.data.date, lang, 'short')}</span>
      </li>
    );
  })}
</ul>

<p class="toc-empty" id="article-empty" hidden>{t('articles.empty')}</p>

<nav class="toc-pager" id="article-pager" aria-label="Pagination" hidden>
  <button type="button" id="page-prev" class="toc-page-btn">{t('articles.prev')}</button>
  <span id="page-numbers" class="toc-page-numbers"></span>
  <button type="button" id="page-next" class="toc-page-btn">{t('articles.next')}</button>
</nav>

<script>
  const PER_PAGE = 10;

  const list      = document.getElementById('article-list') as HTMLUListElement;
  const search    = document.getElementById('article-search') as HTMLInputElement;
  const tagField  = document.getElementById('article-tag-field') as HTMLDivElement;
  const tagChips  = document.getElementById('article-tag-chips') as HTMLSpanElement;
  const tagInput  = document.getElementById('article-tag-input') as HTMLInputElement;
  const resetBtn  = document.getElementById('article-reset') as HTMLButtonElement;
  const emptyMsg  = document.getElementById('article-empty') as HTMLParagraphElement;
  const pager     = document.getElementById('article-pager') as HTMLElement;
  const prevBtn   = document.getElementById('page-prev') as HTMLButtonElement;
  const nextBtn   = document.getElementById('page-next') as HTMLButtonElement;
  const pageNums  = document.getElementById('page-numbers') as HTMLSpanElement;

  const items = Array.from(list.querySelectorAll<HTMLLIElement>('.toc-item'));
  const allTagOptions = Array.from(
    document.querySelectorAll<HTMLOptionElement>('#article-tag-options option')
  ).map(o => o.value);

  let currentPage = 0;
  let visible: HTMLLIElement[] = items.slice();
  const selectedTags = new Set<string>();

  function renderChips() {
    tagChips.textContent = '';
    for (const tag of selectedTags) {
      const chip = document.createElement('span');
      chip.className = 'articles-tag-chip';
      chip.dataset.tag = tag;
      chip.append(document.createTextNode(tag));
      const x = document.createElement('button');
      x.type = 'button';
      x.className = 'articles-tag-chip-remove';
      x.setAttribute('aria-label', 'Remove');
      x.textContent = '×';
      x.addEventListener('click', (e) => {
        e.stopPropagation();
        selectedTags.delete(tag);
        renderChips();
        applyFilter();
      });
      chip.append(x);
      tagChips.append(chip);
    }
  }

  function pickMatchingTag(query: string): string | null {
    const q = query.trim().toLowerCase();
    if (!q) return null;
    for (const opt of allTagOptions) if (opt.toLowerCase() === q) return opt;
    for (const opt of allTagOptions) if (opt.toLowerCase().startsWith(q)) return opt;
    for (const opt of allTagOptions) if (opt.toLowerCase().includes(q)) return opt;
    return null;
  }

  function addTag(tag: string) {
    const t = tag.trim();
    if (!t || selectedTags.has(t)) return;
    selectedTags.add(t);
    renderChips();
    applyFilter();
  }

  function applyFilter() {
    const q = search.value.trim().toLowerCase();
    const sel = Array.from(selectedTags).map(t => t.toLowerCase());
    visible = items.filter(li => {
      const title = li.dataset.title ?? '';
      const tags  = (li.dataset.tags ?? '').split('|');
      if (q && !title.includes(q)) return false;
      for (const s of sel) if (!tags.includes(s)) return false;
      return true;
    });
    currentPage = 0;
    render();
  }

  function render() {
    const totalPages = Math.max(1, Math.ceil(visible.length / PER_PAGE));
    if (currentPage >= totalPages) currentPage = totalPages - 1;
    const start = currentPage * PER_PAGE;
    const end   = start + PER_PAGE;

    for (const li of items) li.style.display = 'none';
    for (const li of visible.slice(start, end)) li.style.display = '';

    emptyMsg.hidden = visible.length > 0;
    pager.hidden    = totalPages <= 1;
    prevBtn.disabled = currentPage === 0;
    nextBtn.disabled = currentPage >= totalPages - 1;

    pageNums.textContent = '';
    for (let i = 0; i < totalPages; i++) {
      const btn = document.createElement('button');
      btn.type        = 'button';
      btn.className   = 'toc-page-num' + (i === currentPage ? ' is-current' : '');
      btn.textContent = String(i + 1);
      btn.addEventListener('click', () => { currentPage = i; render(); });
      pageNums.appendChild(btn);
    }
  }

  search.addEventListener('input', applyFilter);

  tagInput.addEventListener('input', () => {
    const v = tagInput.value;
    if (allTagOptions.includes(v)) {
      addTag(v);
      tagInput.value = '';
    }
  });
  tagInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      const matched = pickMatchingTag(tagInput.value);
      if (matched) {
        addTag(matched);
        tagInput.value = '';
      }
    } else if (e.key === 'Backspace' && !tagInput.value && selectedTags.size > 0) {
      const arr = Array.from(selectedTags);
      const last = arr[arr.length - 1];
      selectedTags.delete(last);
      renderChips();
      applyFilter();
    }
  });
  tagField.addEventListener('click', (e) => {
    if (e.target === tagField || e.target === tagChips) tagInput.focus();
  });

  resetBtn.addEventListener('click', () => {
    search.value = '';
    tagInput.value = '';
    selectedTags.clear();
    renderChips();
    applyFilter();
    search.focus();
  });

  prevBtn.addEventListener('click', () => {
    if (currentPage > 0) { currentPage--; render(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
  });
  nextBtn.addEventListener('click', () => {
    const totalPages = Math.ceil(visible.length / PER_PAGE);
    if (currentPage < totalPages - 1) { currentPage++; render(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
  });

  list.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target.classList.contains('tag-pick')) return;
    e.preventDefault();
    if (target.dataset.tag) addTag(target.dataset.tag);
  });

  render();
</script>
