---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticlePage from '../../../components/ArticlePage.astro';

export async function getStaticPaths() {
  const all = await getCollection('articles', ({ data }) => !data.draft);
  const ruArticles = all.filter(a => a.id.startsWith('ru/'));
  const enSlugs = new Set(
    all.filter(a => a.id.startsWith('en/')).map(a => a.slug.replace('en/', ''))
  );
  const base = import.meta.env.BASE_URL;
  return ruArticles.map(article => {
    const slug = article.slug.replace('ru/', '');
    return {
      params: { slug },
      props: {
        article,
        otherLangUrl: enSlugs.has(slug) ? `${base}/en/articles/${slug}` : undefined,
      },
    };
  });
}

const lang = 'ru';
const { article, otherLangUrl } = Astro.props;
const title = article.data.title ?? article.slug.replace('ru/', '');
---

<BaseLayout title={title} description={article.data.description} lang={lang} otherLangUrl={otherLangUrl}>
  <ArticlePage article={article} lang={lang} />
</BaseLayout>
