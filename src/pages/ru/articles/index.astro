---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations } from '../../../i18n/ui';

const lang = 'ru';
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;

const articles = (await getCollection('articles', ({ data, id }) => !data.draft && id.startsWith('ru/')))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('ru-RU', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title={t('articles.heading')} lang={lang} otherLangUrl={`${base}/en/articles/`}>
  <h1>{t('articles.heading')}</h1>
  <ul class="article-list">
    {articles.map(article => {
      const slug = article.slug.replace('ru/', '');
      return (
        <li>
          <div class="article-list-item">
            <h2>
              <a href={`${base}/ru/articles/${slug}`}>
                {article.data.title ?? slug}
              </a>
            </h2>
            <div class="date">{formatDate(article.data.date)}</div>
            {article.data.description && <p>{article.data.description}</p>}
            {article.data.tags.length > 0 && (
              <div class="tags" style="margin-top: 0.5rem">
                {article.data.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </li>
      );
    })}
  </ul>
</BaseLayout>
