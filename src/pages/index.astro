---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>
  <body>
    <script define:vars={{ base }}>
      const lang = localStorage.getItem('lang') || 'en';
      location.replace(`${base}/${lang}/`);
    </script>
  </body>
</html>
